# ============================================================================
# Document QA System — 环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥
# ============================================================================

# ----- LLM 配置（必填）------------------------------------------------------
# 支持任何 OpenAI-compatible API（DeepSeek、OpenAI、通义千问等）
LLM_MODEL_ID=deepseek-chat
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.0

# ----- Mineru 配置（可选，用于扫描版 PDF OCR）-------------------------------
# 注册地址：https://mineru.net/
MINERU_API_TOKEN=your-mineru-token-here

# ----- 嵌入模型配置（必填）--------------------------------------------------
# Qwen3-Embedding 本地模型路径，或留空自动从 HuggingFace 下载
# BGE_M3_MODEL_PATH=/path/to/models/qwen3-embedding
# 国内用户建议设置镜像（可大幅加速首次下载）
# HF_ENDPOINT=https://hf-mirror.com

# ----- 章节检测独立模型（可选）--------------------------------------------------
# 留空则使用 LLM_MODEL_ID
LLM_CHAPTER_DETECT_MODEL=
LLM_CHAPTER_REVIEW_MODEL=
CHAPTER_DETECT_TIMEOUT=90

# ----- 视觉模型（图片PDF章节检测，可选）-----------------------------------------
# 用于扫描版 PDF 无文字层时的 VLM 兜底
LLM_VISION_MODEL=
LLM_VISION_BASE_URL=
LLM_VISION_API_KEY=

# ----- 搜索工具配置（可选）--------------------------------------------------
# Tavily Search — 免费 1000 次/月，注册地址：https://tavily.com/
TAVILY_API_KEY=tvly-your-key-here

# ----- 可选配置 ------------------------------------------------------------
# 知识提取并发 batch 数
EXTRACT_CONCURRENCY=3
# 章节检测并发文件数
CHAPTER_DETECT_CONCURRENCY=3
# 最大搜索结果数
MAX_SEARCH_RESULTS=3

# ----- 记忆 / 缓存（可选）---------------------------------------------------
# Qdrant Cloud 语义搜索缓存，没有则仅用 SQLite
# QDRANT_URL=https://your-instance.qdrant.cloud:6333
# QDRANT_API_KEY=your-qdrant-api-key
# SQLite 数据库路径，默认项目根目录 memory.db
MEMORY_DB_PATH=storage

# ----- LangSmith 追踪（可选）-------------------------------------------------
# 开启后自动追踪所有 LLM 调用。注册: https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_your-key-here
# LANGCHAIN_PROJECT=research-agent

# ----- 本地 Token 监控（可选）-------------------------------------------------
# 开启后将所有 LLM token 用量写入 storage/token_usage.db
MONITORING_ENABLED=true

# ----- HuggingFace 镜像（国内用户推荐）------------------------------------------
# 国内下载模型需设置镜像
HF_ENDPOINT=https://hf-mirror.com
